# ─── Environment Variables for AI Benchmark Analyzer ────────────────────────
# Copy this file to .env and fill in your actual API key.
# NEVER commit .env to version control.

# Google Gemini API key (free tier available at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Set to "true" to enable verbose API logging
DEBUG_API=false
