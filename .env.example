# ─── Environment Variables for AI Benchmark Analyzer ─────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Node.js / Web Server ─────────────────────────────────────────────────────

# Port the Express server listens on
PORT=5002

# Gemini API key — enables LLM-powered dataset analysis in the Custom Benchmark tab
# Get a free key: https://aistudio.google.com/app/apikey
# Leave as-is to fall back to rule-based analysis (no key required for demos)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used for dataset classification (gemini-2.5-flash recommended)
DATASET_ANALYZER_MODEL=gemini-2.5-flash

# Remote model source URL — leave blank to use local data/models.json
MODELS_API_URL=

# Enable verbose API response logging
DEBUG_API=false

# ─── Python / FastAPI (only needed when running api.py) ───────────────────────

ENVIRONMENT=development

# PostgreSQL connection string
DB_URL=postgresql://benchmark_user:benchmark_pass@localhost:5432/benchmark_db

# Redis — used by the Python API for response caching
CACHE_URL=redis://localhost:6379/0
CACHE_TTL=3600
CACHE_ENABLED=true

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_VERSION=1.0.0

# Structured logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log

# Benchmark engine
BENCHMARK_TIMEOUT=300
BENCHMARK_MAX_PARALLEL=10
BENCHMARK_RETRY_ATTEMPTS=3
BENCHMARK_RETRY_DELAY=1.0
